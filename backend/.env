# ─── Django ───────────────────────────────────────────────────────────────────
DJANGO_ENV=development
DJANGO_SETTINGS_MODULE=config.settings
SECRET_KEY=your-secret-key-here-generate-with-python-secrets

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=fotopro
POSTGRES_USER=fotopro
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://mongo:27017
MONGO_DB_NAME=fotopro_meta

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── S3 / MinIO ───────────────────────────────────────────────────────────────
USE_S3=True
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=fotopro-media
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ENDPOINT_URL=http://minio:9000
# AWS_CLOUDFRONT_DOMAIN=your-cdn.cloudfront.net   # CDN domain (production)

# ─── Photo Processing ─────────────────────────────────────────────────────────
WATERMARK_TEXT=© FotoPro
WATERMARK_OPACITY=0.35
WATERMARK_FONT_SCALE=0.05
MAX_UPLOAD_SIZE_MB=50

# ─── Download Tokens ──────────────────────────────────────────────────────────
DOWNLOAD_TOKEN_SECRET=generate-a-strong-random-secret
DOWNLOAD_TOKEN_MAX_AGE=3600

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Sentry (production only) ─────────────────────────────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/yyy
# ENVIRONMENT=production

# ─── Email (production only) ──────────────────────────────────────────────────
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_HOST_PASSWORD=your-api-key
# DEFAULT_FROM_EMAIL=noreply@fotopro.com
